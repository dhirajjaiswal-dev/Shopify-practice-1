<section class="bestseller-bundles">
  <div class="bestseller-bundles__wrapper">
    {% if section.settings.heading != blank %}
      <h2 class="bestseller-bundles__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% assign collection = collections[section.settings.collection] %}

    {% if collection != blank %}
      <div class="bestseller-bundles__grid">
        {% for product in collection.products limit: 4 %}
          <a href="{{ product.url }}" class="bestseller-bundles__card bestseller-bundles__card--link">
            <!-- Image -->
            <div class="bestseller-bundles__image-wrapper">
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title }}"
                class="bestseller-bundles__image"
                loading="lazy"
                width="600"
                height="600"
              >
            </div>

            <!-- Content -->
            <div class="bestseller-bundles__content">
              <h3 class="bestseller-bundles__title">
                {{ product.title }}
              </h3>

              <!-- Price -->
              <div class="bestseller-bundles__price">
                <span class="bestseller-bundles__price-label">From</span>
                <div class="bestseller-bundles__price-group">
                  <span class="bestseller-bundles__price-current">
                    {{ product.price | money }}
                  </span>
                  {% if product.compare_at_price > product.price %}
                    <span class="bestseller-bundles__price-original">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>
              </div>

              <!-- Add to Cart -->
              <form method="post" action="/cart/add" class="bestseller-bundles__form" onclick="event.stopPropagation();">
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                >

                <button
                  type="submit"
                  class="bestseller-bundles__btn"
                >
                  Add to Cart
                </button>
              </form>
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <p class="bestseller-bundles__empty">Please select a collection in section settings.</p>
    {% endif %}
  </div>
</section>

<style>
  .bestseller-bundles {
    padding: 60px 40px;
    background-color: #f5f0ed;
  }

  .bestseller-bundles__wrapper {
    max-width: 1400px;
    margin: 0 auto;
  }

  .bestseller-bundles__heading {
    text-align: center;
    font-size: 48px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 50px;
    text-transform: capitalize;
  }

  .bestseller-bundles__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .bestseller-bundles__card {
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .bestseller-bundles__card:hover {
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    transform: translateY(-4px);
  }

  .bestseller-bundles__image-wrapper {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f9f3f1;
  }

  .bestseller-bundles__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .bestseller-bundles__card:hover .bestseller-bundles__image {
    transform: scale(1.05);
  }

  .bestseller-bundles__content {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .bestseller-bundles__title {
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .bestseller-bundles__price {
    margin-bottom: 20px;
  }

  .bestseller-bundles__price-label {
    font-size: 13px;
    color: #666;
    display: block;
    margin-bottom: 4px;
  }

  .bestseller-bundles__price-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bestseller-bundles__price-current {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .bestseller-bundles__price-original {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
  }

  .bestseller-bundles__form {
    margin-top: auto;
  }

  .bestseller-bundles__btn {
    width: 100%;
    background-color: #025A60;
    color: #ffffff;
    padding: 14px 24px;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .bestseller-bundles__btn:hover {
    background-color: #023e44;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(2, 90, 96, 0.3);
  }

  .bestseller-bundles__empty {
    text-align: center;
    color: #666;
    font-size: 16px;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .bestseller-bundles {
      padding: 50px 30px;
    }

    .bestseller-bundles__heading {
      font-size: 36px;
      margin-bottom: 40px;
    }

    .bestseller-bundles__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .bestseller-bundles__title {
      font-size: 18px;
    }

    .bestseller-bundles__price-current {
      font-size: 18px;
    }
  }

  @media (max-width: 640px) {
    .bestseller-bundles {
      padding: 40px 20px;
    }

    .bestseller-bundles__heading {
      font-size: 28px;
      margin-bottom: 30px;
    }

    .bestseller-bundles__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .bestseller-bundles__title {
      font-size: 16px;
    }

    .bestseller-bundles__content {
      padding: 20px;
    }

    .bestseller-bundles__price-current {
      font-size: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Bestseller Bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wellie Bestseller Bundles"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    }
  ],
  "presets": [
    {
      "name": "Bestseller Bundles"
    }
  ]
}
{% endschema %}
