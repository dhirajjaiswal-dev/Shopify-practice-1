<section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-7">
  {% if section.settings.heading != blank %}
    <h2 class="text-xl md:text-2xl lg:text-3xl font-semibold text-gray-800 mb-6 md:mb-10">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  {% assign collection = collections[section.settings.collection] %}

  {% if collection != blank %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for product in collection.products limit: 4 %}
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col">
          <!-- Image -->
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.title }}"
              class="w-full h-full object-cover"
              loading="lazy"
              width="600"
              height="600"
            >
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col flex-1">
            <h3 class="text-sm font-semibold text-gray-800 mb-3">
              {{ product.title }}
            </h3>

            <!-- Price -->
            <div class="mb-6">
              <span class="text-sm text-gray-500">From</span>
              <div class="flex items-center gap-2">
                <span class="text-lg font-semibold text-gray-800">
                  {{ product.price | money }}
                </span>
                {% if product.compare_at_price > product.price %}
                  <span class="text-sm text-gray-400 line-through">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>
            </div>

            <!-- Add to Cart -->
            <form method="post" action="/cart/add" class="mt-auto">
              <input
                type="hidden"
                name="id"
                value="{{ product.selected_or_first_available_variant.id }}"
              >

              <button
                type="submit"
                class="w-full bg-teal-700 text-white py-3 rounded-xl font-semibold hover:bg-teal-800 transition"
              >
                🛒 Add to Cart
              </button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-center text-gray-500">Please select a collection in section settings.</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Bestseller Bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wellie Bestseller Bundles"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    }
  ],
  "presets": [
    {
      "name": "Bestseller Bundles"
    }
  ]
}
{% endschema %}
