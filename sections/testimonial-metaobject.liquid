{% assign testimonials = product.metafields.custom.testimonial.value %}

{% if testimonials != blank %}
  <div class="bg-[#FAF7F5] py-12 px-4 md:px-6 lg:px-20">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-10">
      Hear from our Customers!
    </h2>

    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for entry in testimonials %}
        <div class="flex gap-4 bg-white rounded-2xl p-4 shadow-sm overflow-hidden min-h-[200px]">

          <!-- Left: Customer Image -->
          {% if entry.customer_image.value != blank %}
            <div class="w-36 flex-shrink-0 overflow-hidden rounded-xl">
              <img
                src="{{ entry.customer_image.value | image_url: width: 300 }}"
                class="w-full h-full object-cover"
                loading="lazy"
                alt="{{ entry.profile_name.value }}"
                width="144"
                height="200"
              >
            </div>
          {% endif %}

          <!-- Right: Content -->
          <div class="flex flex-col justify-between flex-1 overflow-hidden">

            <!-- Quote icon + Stars -->
            <div>
              {% if entry.quote_img.value != blank %}
                <img
                  src="{{ entry.quote_img.value | image_url: width: 60 }}"
                  class="w-7 h-7 mb-1"
                  loading="lazy"
                  alt="quote"
                  width="28"
                  height="28"
                >
              {% endif %}

              <!-- Dynamic stars -->
              {% assign rating = entry.stars.value | plus: 0.0 %}
              {% assign full_stars = rating | floor %}
              {% assign decimal = rating | minus: full_stars %}
              {% assign has_half = false %}
              {% if decimal >= 0.5 %}{% assign has_half = true %}{% endif %}
              {% if has_half %}
                {% assign empty_stars = 5 | minus: full_stars | minus: 1 %}
              {% else %}
                {% assign empty_stars = 5 | minus: full_stars %}
              {% endif %}

              <div class="flex items-center gap-0.5">
                {% for i in (1..full_stars) %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#fb923c" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}

                {% if has_half %}
                  <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                      <linearGradient id="half-{{ forloop.index }}">
                        <stop offset="50%" stop-color="#fb923c"/>
                        <stop offset="50%" stop-color="#d1d5db"/>
                      </linearGradient>
                    </defs>
                    <path fill="url(#half-{{ forloop.index }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endif %}

                {% for i in (1..empty_stars) %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#d1d5db" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}
              </div>
            </div>

            <!-- Review text -->
            {% if entry.review.value != blank %}
              <p class="text-sm text-gray-700 leading-snug mt-2 line-clamp-4">
                {{ entry.review.value }}
              </p>
            {% endif %}

            <!-- Author -->
            <div class="flex items-center gap-2 mt-3">
              {% if entry.profile_pic.value != blank %}
                <img
                  src="{{ entry.profile_pic.value | image_url: width: 60 }}"
                  class="w-7 h-7 rounded-full object-cover flex-shrink-0"
                  loading="lazy"
                  alt="{{ entry.profile_name.value }}"
                  width="28"
                  height="28"
                >
              {% endif %}
              {% if entry.profile_name.value != blank %}
                <span class="text-xs font-semibold text-gray-900">
                  {{ entry.profile_name.value }}
                </span>
              {% endif %}
            </div>

          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Testimonial (Metaobject)",
  "settings": [],
  "presets": [
    {
      "name": "Testimonial (Metaobject)"
    }
  ]
}
{% endschema %}
