{% assign testimonials = product.metafields.custom.testimonial.value %}

{% if testimonials != blank %}

<style>
  /* ── Mobile slider ── */
  .testimonial-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;          /* Firefox */
    gap: 0;
    padding-bottom: 4px;            /* prevent shadow clipping */
  }
  .testimonial-track::-webkit-scrollbar { display: none; }

  /* Each card fills the visible width on mobile */
  .testimonial-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: 100%;                    /* one card per screen on mobile */
    padding: 0 16px;                /* side padding so card doesn't bleed to edges */
    box-sizing: border-box;
  }

  /* Dot navigation */
  .testimonial-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .testimonial-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .testimonial-dot.is-active {
    background-color: #e57373;      /* pink/salmon from Figma */
    width: 10px;
    height: 10px;
  }

  /* ── Desktop: revert to grid ── */
  @media (min-width: 768px) {
    .testimonial-track {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }
    .testimonial-card {
      width: auto;
      padding: 0;
    }
    .testimonial-dots {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .testimonial-track {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<div class="bg-[#FAF7F5] py-12 px-0 md:px-6 lg:px-20">

  <!-- Section heading -->
  <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-8 px-4">
    Hear from our Customers!
  </h2>

  <div class="max-w-7xl mx-auto">

    <!-- Scrollable track (mobile) / grid (desktop) -->
    <div class="testimonial-track" data-testimonial-track>

      {% for entry in testimonials %}
        <!-- Editable: each entry is a testimonial metaobject row -->
        <div class="testimonial-card">
          <div class="flex gap-4 bg-white rounded-2xl p-4 shadow-sm overflow-hidden h-[200px]">

            <!-- Left: full-height customer photo -->
            {% if entry.customer_image.value != blank %}
              <div class="w-[130px] flex-shrink-0 overflow-hidden rounded-xl self-stretch">
                <img
                  src="{{ entry.customer_image.value | image_url: width: 300 }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  alt="{{ entry.profile_name.value }}"
                  width="130"
                  height="200"
                >
              </div>
            {% endif %}

            <!-- Right: quote / stars / review / author -->
            <div class="flex flex-col justify-between flex-1 overflow-hidden py-1">

              <div>
                <!-- Quote icon (editable: upload quote image to metaobject) -->
                {% if entry.quote_img.value != blank %}
                  <img
                    src="{{ entry.quote_img.value | image_url: width: 60 }}"
                    class="w-7 h-7 mb-1"
                    loading="lazy"
                    alt="quote"
                    width="28"
                    height="28"
                  >
                {% endif %}

                <!-- Dynamic star rating (editable: set stars field on metaobject) -->
                {% assign rating = entry.stars.value | plus: 0.0 %}
                {% assign full_stars = rating | floor %}
                {% assign decimal = rating | minus: full_stars %}
                {% assign has_half = false %}
                {% if decimal >= 0.5 %}{% assign has_half = true %}{% endif %}
                {% if has_half %}
                  {% assign empty_stars = 5 | minus: full_stars | minus: 1 %}
                {% else %}
                  {% assign empty_stars = 5 | minus: full_stars %}
                {% endif %}

                <div class="flex items-center gap-0.5 mt-1">
                  {% for i in (1..full_stars) %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#fb923c" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endfor %}

                  {% if has_half %}
                    <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="half-{{ forloop.index }}">
                          <stop offset="50%" stop-color="#fb923c"/>
                          <stop offset="50%" stop-color="#d1d5db"/>
                        </linearGradient>
                      </defs>
                      <path fill="url(#half-{{ forloop.index }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endif %}

                  {% for i in (1..empty_stars) %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#d1d5db" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endfor %}
                </div>
              </div>

              <!-- Review text (editable: review field on metaobject) -->
              {% if entry.review.value != blank %}
                <p class="text-sm text-gray-700 leading-snug mt-2 line-clamp-4">
                  {{ entry.review.value }}
                </p>
              {% endif %}

              <!-- Author row: profile pic + name (editable: profile_pic / profile_name on metaobject) -->
              <div class="flex items-center gap-2 mt-3">
                {% if entry.profile_pic.value != blank %}
                  <img
                    src="{{ entry.profile_pic.value | image_url: width: 60 }}"
                    class="w-8 h-8 rounded-full object-cover flex-shrink-0"
                    loading="lazy"
                    alt="{{ entry.profile_name.value }}"
                    width="32"
                    height="32"
                  >
                {% endif %}
                {% if entry.profile_name.value != blank %}
                  <span class="text-xs font-semibold text-gray-900 leading-tight">
                    {{ entry.profile_name.value }}
                  </span>
                {% endif %}
              </div>

            </div>
          </div>
        </div>
      {% endfor %}

    </div>

    <!-- Dot indicators (mobile only, hidden on md+) -->
    <div class="testimonial-dots" data-testimonial-dots aria-hidden="true">
      {% for entry in testimonials %}
        <button
          class="testimonial-dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to testimonial {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>

  </div>
</div>

<script>
  (function () {
    var track = document.querySelector('[data-testimonial-track]');
    var dots  = document.querySelectorAll('[data-testimonial-dots] .testimonial-dot');

    if (!track || !dots.length) return;

    // Update active dot based on scroll position
    function updateDots() {
      var cardWidth = track.scrollWidth / dots.length;
      var index = Math.round(track.scrollLeft / cardWidth);
      dots.forEach(function (dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    // Scroll to card when dot is clicked
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var index = parseInt(dot.getAttribute('data-index'), 10);
        var cardWidth = track.scrollWidth / dots.length;
        track.scrollTo({ left: cardWidth * index, behavior: 'smooth' });
      });
    });

    track.addEventListener('scroll', updateDots, { passive: true });
  })();
</script>

{% endif %}

{% schema %}
{
  "name": "Testimonial (Metaobject)",
  "settings": [],
  "presets": [
    {
      "name": "Testimonial (Metaobject)"
    }
  ]
}
{% endschema %}
