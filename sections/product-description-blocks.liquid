<section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-10">
  <div class="border border-[#025A60]/40 rounded-xl p-6 md:p-8 bg-[#FFF9F7]">
    <!-- Heading -->
    <h2 class="text-lg font-semibold text-gray-900 mb-4">
      {{ section.settings.heading }}
    </h2>
    <hr>

    <div class="space-y-4 mt-4 text-sm text-gray-700 leading-relaxed">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'paragraph' %}
            <p {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </p>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Description",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Description"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add your product description text here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Description",
      "blocks": [{ "type": "paragraph" }, { "type": "paragraph" }, { "type": "paragraph" }]
    }
  ]
}
{% endschema %}
