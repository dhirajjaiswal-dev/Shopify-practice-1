{% schema %}
{
  "name": "Feature Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#EC2C86"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Scientifically Formulated"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Marquee",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .marquee-track {
    animation: marquee linear infinite;
  }
</style>

<section
  class="w-full overflow-hidden"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div
    class="marquee-track flex w-max items-center gap-4 md:gap-8 py-2 md:py-3"
    style="animation-duration: {{ section.settings.speed }}s;"
  >
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <div
          class="flex items-center gap-2 text-xs md:text-sm font-semibold whitespace-nowrap"
          style="color: {{ section.settings.text_color }};"
        >
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 40 }}"
              alt=""
              class="h-4 w-4 md:h-5 md:w-5 object-contain"
              width="20"
              height="20"
              loading="eager"
            >
          {% endif %}

          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>
