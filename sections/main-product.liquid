<style>
  /* ── Mobile image slider (< 768px only) ── */

  .mp-slider-wrapper {
    position: relative;
  }

  /* Scrollable track — no border-radius here to avoid implicit overflow clip */
  .mp-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .mp-track::-webkit-scrollbar { display: none; }

  /* Each slide: slightly narrower so next slide peeks ~36px on the right */
  .mp-slide {
    flex-shrink: 0;
    width: calc(100% - 36px);
    margin-right: 8px;
    scroll-snap-align: start;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #fff;
  }
  .mp-slide:last-child { margin-right: 0; }

  .mp-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Arrow buttons — !important needed to beat base.css svg height:auto */
  .mp-arrow {
    position: absolute !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    width: 32px !important;
    height: 32px !important;
    min-width: 32px !important;
    min-height: 32px !important;
    max-width: 32px !important;
    max-height: 32px !important;
    border-radius: 50% !important;
    background: #E52888 !important;
    border: 0.5px solid #D4E391 !important;
    box-shadow: 0.5px 0.5px 0px #D4E391 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
    z-index: 10 !important;
    cursor: pointer !important;
    padding: 0 !important;
  }
  .mp-arrow--prev { left: 10px !important; }
  /* right edge of slide = wrapper_width - 36px; arrow right edge = that - 10px gap */
  .mp-arrow--next { right: 46px !important; }

  /* Stop base.css svg { height: auto } from stretching arrow SVGs */
  .mp-arrow svg {
    width: 6px !important;
    height: 10px !important;
    flex-shrink: 0 !important;
    display: block !important;
  }

  /* Thumbnails */
  .mp-thumbs {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .mp-thumbs::-webkit-scrollbar { display: none; }

  .mp-thumb {
    position: relative;
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    border: 2.5px solid transparent;
    cursor: pointer;
    padding: 0;
    background: transparent;
  }
  .mp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 6px;
  }
  /* White overlay for inactive thumbnails */
  .mp-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.55);
    border-radius: 6px;
    transition: opacity 0.2s;
  }
  /* Active: teal border, no overlay */
  .mp-thumb.is-active {
    border-color: #025A60;
  }
  .mp-thumb.is-active::after {
    display: none;
  }
</style>

<section class="w-full bg-[#f9f3f1] py-10">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

      <!-- LEFT: PRODUCT IMAGES -->
      <div>

        <!-- ── MOBILE SLIDER (hidden on md+) ── -->
        <div class="md:hidden">
          <div class="mp-slider-wrapper" data-mp-slider>

            <!-- Scrollable track -->
            <div class="mp-track" data-mp-track>
              {% for image in product.images %}
                <div class="mp-slide">
                  <img
                    src="{{ image | image_url: width: 900 }}"
                    alt="{{ product.title }}"
                    width="900"
                    height="900"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  >
                </div>
              {% endfor %}
            </div>

            
            <!-- Left arrow -->
            <button
              type="button"
              class="mp-arrow mp-arrow--prev"
              data-mp-prev
              aria-label="Previous image"
            >
              <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 1L1 5L5 9" stroke="#D4E391" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <!-- Right arrow -->
            <button
              type="button"
              class="mp-arrow mp-arrow--next"
              data-mp-next
              aria-label="Next image"
            >
              <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L5 5L1 9" stroke="#D4E391" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

          </div>

          <!-- Thumbnails -->
          <div class="mp-thumbs" data-mp-thumbs>
            {% for image in product.images %}
              <button
                type="button"
                class="mp-thumb {% if forloop.first %}is-active{% endif %}"
                data-mp-thumb="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ product.title }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </button>
            {% endfor %}
          </div>
        </div>

        <!-- ── DESKTOP (unchanged, hidden on mobile) ── -->
        <div class="hidden md:block">
          <div class="rounded-2xl overflow-hidden bg-white border">
            <img
              id="MainProductImage"
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.title }}"
              class="w-full h-auto object-cover"
              width="900"
              height="900"
              loading="eager"
            >
          </div>

          <!-- Desktop Thumbnails -->
          <div class="flex gap-3 mt-4">
            {% for image in product.images %}
              <button
                type="button"
                onclick="document.getElementById('MainProductImage').src='{{ image | image_url: width: 900 }}'"
                class="border rounded-lg p-1 hover:border-black"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ product.title }}"
                  class="w-20 h-20 object-cover rounded"
                  width="120"
                  height="120"
                  loading="lazy"
                >
              </button>
            {% endfor %}
          </div>
        </div>

      </div>

      <!-- RIGHT: PRODUCT DETAILS — unchanged -->
      <div>
        {% if section.settings.badge_text != blank %}
          <span class="inline-block bg-pink-100 text-pink-600 text-sm font-semibold px-3 py-1 rounded-full mb-4">
            {{ section.settings.badge_text }}
          </span>
        {% endif %}

        <h1 class="text-2xl md:text-4xl font-bold mb-2" style="color: #025A60;">
          {{ product.title }}
        </h1>

        <!-- Price -->
        <div class="flex items-center gap-3 mb-1">
          <span id="ProductPrice" class="text-xl md:text-2xl font-bold">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>

          <span id="ProductComparePriceWrapper" {% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}style="display:none"{% endunless %}>
            <span id="ProductComparePrice" class="line-through text-gray-400">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
          </span>
        </div>

        <p class="text-sm text-gray-500 mb-4">MRP Inclusive of all taxes</p>

        <!-- Benefit Box -->
        {% if section.settings.benefit_text != blank %}
          <div class="bg-pink-50 border border-pink-200 rounded-xl p-4 mb-6">
            <div class="font-semibold text-pink-700 mb-1">
              {{ section.settings.benefit_title }}
            </div>
            <p class="text-sm text-gray-600">
              {{ section.settings.benefit_text }}
            </p>
          </div>
        {% endif %}

        <!-- PRODUCT FORM -->
        <form method="post" action="/cart/add" id="product-form" class="space-y-6">
          <input
            type="hidden"
            name="id"
            value="{{ product.selected_or_first_available_variant.id }}"
          >

          <!-- Variants -->
          {% if product.variants.size > 1 %}
            <div>
              <p class="font-semibold mb-2">Select Size</p>
              <div class="flex flex-wrap gap-3">
                {% for variant in product.variants %}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="id"
                      value="{{ variant.id }}"
                      class="hidden peer variant-price-radio"
                      data-price="{{ variant.price | money }}"
                      data-compare-price="{{ variant.compare_at_price | money }}"
                      data-has-compare="{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}"
                      {% if variant == product.selected_or_first_available_variant %}
                        checked
                      {% endif %}
                    >
                    <span class="px-4 py-2 border rounded-full peer-checked:bg-teal-700 peer-checked:text-black">
                      {{ variant.title }}
                    </span>
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <!-- Quantity + Add to Cart -->
          <div class="flex gap-4">
            <input
              type="number"
              name="quantity"
              value="1"
              min="1"
              class="w-16 md:w-20 border rounded-lg text-center"
            >

            <button
              type="submit"
              class="flex-1 bg-teal-700 text-white py-3 rounded-xl font-semibold hover:bg-teal-800 transition"
            >
              🛒 Add to Cart
            </button>
          </div>

          <!-- Buy Now -->
          <button
            type="submit"
            name="checkout"
            class="w-full border border-teal-700 text-teal-700 py-3 rounded-xl font-semibold"
          >
            Buy It Now
          </button>
        </form>

        <!-- Offers -->
        {% if section.settings.offer_text != blank %}
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
            <div class="border rounded-xl p-3 text-sm">
              {{ section.settings.offer_text }}
            </div>
            <div class="border rounded-xl p-3 text-sm">
              {{ section.settings.offer_text }}
            </div>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    var slider = document.querySelector('[data-mp-slider]');
    if (!slider) return;

    var track  = slider.querySelector('[data-mp-track]');
    var thumbs = Array.from(slider.parentElement.querySelectorAll('[data-mp-thumb]'));
    var prevBtn = slider.querySelector('[data-mp-prev]');
    var nextBtn = slider.querySelector('[data-mp-next]');
    var total  = thumbs.length;
    var current = 0;

    function slideWidth() {
      var first = track.firstElementChild;
      return first ? first.offsetWidth + 10 : track.offsetWidth; /* width + margin-right */
    }

    function goTo(index) {
      current = (index + total) % total;
      track.scrollTo({ left: slideWidth() * current, behavior: 'smooth' });
      thumbs.forEach(function (t, i) {
        t.classList.toggle('is-active', i === current);
      });
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

    thumbs.forEach(function (t) {
      t.addEventListener('click', function () {
        goTo(parseInt(t.getAttribute('data-mp-thumb'), 10));
      });
    });

    /* Sync active thumb on manual swipe */
    track.addEventListener('scroll', function () {
      var idx = Math.round(track.scrollLeft / slideWidth());
      if (idx !== current && idx >= 0 && idx < total) {
        current = idx;
        thumbs.forEach(function (t, i) {
          t.classList.toggle('is-active', i === current);
        });
      }
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Main Product",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Top Badge Text",
      "default": "India's #1 Advanced Dog Food"
    },
    {
      "type": "text",
      "id": "benefit_title",
      "label": "Benefit Title",
      "default": "🧬 30% Digestive Health Improvement"
    },
    {
      "type": "textarea",
      "id": "benefit_text",
      "label": "Benefit Description",
      "default": "Results may vary based on pet size, diet, and health."
    },
    {
      "type": "textarea",
      "id": "offer_text",
      "label": "Offer Text",
      "default": "🎁 Get it for ₹3,190 — Copy code to get 10% off"
    }
  ]
}
{% endschema %}
