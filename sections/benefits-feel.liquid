<section class="benefits-feel" style="background-color: {{ section.settings.bg_color }}">
  <div class="benefits-feel__container">
    <!-- Heading -->
    <h2 class="benefits-feel__heading">
      {{ section.settings.heading }}
    </h2>

    <!-- Benefits Grid -->
    <div class="benefits-feel__grid">
      {% for block in section.blocks %}
        <div class="benefits-feel__item" {{ block.shopify_attributes }}>
          <div class="benefits-feel__number">
            {{ block.settings.number }}
          </div>
          <div class="benefits-feel__content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Decorative Icons -->
  <div class="benefits-feel__decorations">
    {% if section.settings.icon_left != blank %}
      <img
        src="{{ section.settings.icon_left | image_url: width: 150 }}"
        alt="Benefits Feel Left Icon"
        class="benefits-feel__icon benefits-feel__icon--left"
        loading="lazy"
        width="120"
        height="120"
      >
    {% endif %}
    {% if section.settings.icon_right != blank %}
      <img
        src="{{ section.settings.icon_right | image_url: width: 150 }}"
        alt="Benefits Feel Right Icon"
        class="benefits-feel__icon benefits-feel__icon--right"
        loading="lazy"
        width="120"
        height="120"
      >
    {% endif %}
  </div>
</section>

<style>
  .benefits-feel {
    padding: 60px 60px 100px;
    color: #fff;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    margin: 40px auto;
    max-width: 1280px;
  }

  .benefits-feel__container {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .benefits-feel__heading {
    text-align: center;
    font-size: 52px;
    font-style: normal;
    font-weight: 800;
    margin-bottom: 70px;
    position: relative;
    display: inline-block;
    width: 100%;
    line-height: 1.15;
  }

  /* Two-line underline: longer on top, shorter below */
  .benefits-feel__heading::after,
  .benefits-feel__heading::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background-color: #fff;
    border-radius: 3px;
    height: 4px;
  }

  .benefits-feel__heading::after {
    bottom: -14px;
    width: 320px;
  }

  .benefits-feel__heading::before {
    bottom: -24px;
    width: 180px;
  }

  /* Column-first grid: items fill down each column (1,2 left; 3,4 right) */
  .benefits-feel__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, auto);
    grid-auto-flow: column;
    gap: 48px 100px;
    padding-top: 20px;
  }

  .benefits-feel__item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .benefits-feel__number {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .benefits-feel__content h3 {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .benefits-feel__content p {
    font-size: 15px;
    line-height: 1.65;
    opacity: 0.92;
    font-weight: 400;
  }

  .benefits-feel__decorations {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .benefits-feel__icon {
    position: absolute;
    bottom: 16px;
    opacity: 1;
  }

  .benefits-feel__icon--left {
    left: 30px;
    width: 110px;
    height: 110px;
  }

  .benefits-feel__icon--right {
    right: 30px;
    width: 130px;
    height: auto;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .benefits-feel {
      padding: 50px 40px 100px;
    }

    .benefits-feel__heading {
      font-size: 38px;
      margin-bottom: 54px;
    }

    .benefits-feel__heading::after {
      width: 220px;
    }

    .benefits-feel__heading::before {
      width: 130px;
    }

    .benefits-feel__grid {
      gap: 36px 60px;
    }

    .benefits-feel__content h3 {
      font-size: 18px;
    }

    .benefits-feel__content p {
      font-size: 14px;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .benefits-feel {
      padding: 36px 20px 120px;
      margin: 0;
      border-radius: 0;
    }

    .benefits-feel__heading {
      text-align: left;
      font-size: 34px;
      font-weight: 800;
      margin-bottom: 40px;
    }

    .benefits-feel__heading::after {
      left: 0;
      transform: none;
      width: 160px;
      bottom: -14px;
    }

    .benefits-feel__heading::before {
      left: 0;
      transform: none;
      width: 100px;
      bottom: -24px;
    }

    /* Mobile: single column, row-first ordering */
    .benefits-feel__grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-flow: row;
      gap: 28px;
    }

    .benefits-feel__number {
      width: 38px;
      height: 38px;
      font-size: 15px;
    }

    .benefits-feel__content h3 {
      font-size: 17px;
    }

    .benefits-feel__content p {
      font-size: 14px;
    }

    .benefits-feel__icon--left {
      width: 80px;
      height: 80px;
      left: 16px;
    }

    .benefits-feel__icon--right {
      width: 100px;
      right: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Benefits – Pet Can Feel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits your pet can feel."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#EC2C86"
    },
    {
      "type": "image_picker",
      "id": "icon_left",
      "label": "Left Icon Image"
    },
    {
      "type": "image_picker",
      "id": "icon_right",
      "label": "Right Icon Image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Supports Digestive Health"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Prebiotics, probiotics, and enzymes help maintain a healthy gut and smooth digestion."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Benefits – Pet Can Feel",
      "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }]
    }
  ]
}
{% endschema %}
