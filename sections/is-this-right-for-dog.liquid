<section class="max-w-7xl mx-auto px-20 py-7">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- LEFT IMAGE -->
    <div
      class="rounded-2xl p-8 flex items-center justify-center"
      style="background-color: {{ section.settings.bg_color }};"
    >
      {% if section.settings.main_image != blank %}
        <img
          src="{{ section.settings.main_image | image_url: width: 700 }}"
          alt="Dog"
          class="max-h-[480px] object-contain"
          loading="lazy"
          width="700"
          height="700"
        >
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div>
      <h2 class="text-3xl font-semibold text-gray-800 mb-10">
        {{ section.settings.heading }}
      </h2>

      <div class="space-y-8">
        {% for block in section.blocks %}
          <div class="flex gap-5 pb-8 border-b last:border-b-0">
            <!-- Icon -->
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 80 }}"
                alt=""
                class="w-14 h-14 rounded-lg object-cover flex-shrink-0 border border-pink-400"
                loading="lazy"
                width="80"
                height="80"
              >
            {% endif %}

            <!-- Text -->
            <div>
              <h3 class="text-lg font-semibold text-gray-800 mb-1">
                {{ block.settings.title }}
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                {{ block.settings.description }}
              </p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Is This Right For My Dog",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Is this right for my dog?"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Left background color",
      "default": "#CBEA5C"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Left main image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Supports Healthy Teeth and Gums"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Designed to promote oral wellness, these dental sticks help support strong, healthy teeth and gums with every chew."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Is This Right For My Dog",
      "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }]
    }
  ]
}
{% endschema %}
