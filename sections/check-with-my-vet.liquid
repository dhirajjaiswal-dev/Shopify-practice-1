<section class="max-w-7xl mx-auto px-6 lg:px-20 py-10">
  <div class="bg-[#FAF7F5] rounded-2xl overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-10">
      <!-- Image -->
      {% if section.settings.image != blank %}
        <div>
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.heading }}"
            class="w-full h-full object-cover rounded-2xl"
            loading="lazy"
            width="900"
            height="900"
          >
        </div>
      {% endif %}

      <!-- Content -->
      <div class="px-4 sm:px-8 lg:px-12 py-10">
        <h2 class="text-2xl lg:text-3xl font-semibold text-gray-800 mb-4">
          {{ section.settings.heading }}
        </h2>

        <!-- Text to Copy -->
        <p
          id="vet-description-{{ section.id }}"
          class="text-gray-600 leading-relaxed mb-6"
        >
          {{ section.settings.description }}
        </p>

        <!-- Copy Button -->
        <button
          type="button"
          onclick="copyVetText('{{ section.id }}')"
          class="inline-flex items-center gap-2 bg-teal-100 text-teal-800 px-6 py-3 rounded-full font-medium hover:bg-teal-200 transition"
        >
          <img
            src="https://cdn.shopify.com/s/files/1/0733/3986/3212/files/File.png?v=1768355583"
            width="20"
            height="20"
          >
          <span id="copy-btn-text-{{ section.id }}">Copy Message</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  function copyVetText(sectionId) {
    const text = document.getElementById(`vet-description-${sectionId}`).innerText;
    const btnText = document.getElementById(`copy-btn-text-${sectionId}`);

    navigator.clipboard.writeText(text).then(() => {
      const originalText = btnText.innerText;
      btnText.innerText = 'Copied!';

      setTimeout(() => {
        btnText.innerText = originalText;
      }, 2000);
    });
  }
</script>

{% schema %}
{
  "name": "Check with my vet",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check with my vet"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Copy Message"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Check with my vet"
    }
  ]
}
{% endschema %}
