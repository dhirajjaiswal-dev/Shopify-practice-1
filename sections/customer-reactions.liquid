<h2 class="text-xl md:text-2xl lg:text-3xl font-semibold mb-3 text-center text-gray-900 pt-8">Love at First Bite</h2>
<p class="text-center text-sm md:text-base text-gray-600">Real dogs. Real reactions. Zero convincing required.</p>

<section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-10">
  <!-- Slider Wrapper -->
  <div class="relative">
    <!-- Left Arrow -->
    <button
      type="button"
      data-slide-prev
      class="
        absolute left-0 top-1/2 -translate-y-1/2 z-10
        bg-white/90 hover:bg-white
        w-10 h-10 rounded-full shadow
        hidden sm:flex items-center justify-center
      "
    >
      ‹
    </button>

    <!-- Right Arrow -->
    <button
      type="button"
      data-slide-next
      class="
        absolute right-0 top-1/2 -translate-y-1/2 z-10
        bg-white/90 hover:bg-white
        w-10 h-10 rounded-full shadow
        hidden sm:flex items-center justify-center
      "
    >
      ›
    </button>

    <!-- Slider -->
    <div
      id="reviewSlider"
      data-review-slider
      class="flex gap-4 overflow-x-auto scroll-smooth no-scrollbar px-8 md:px-12"
    >
      {% for block in section.blocks %}
        <div
          class="
            min-w-[180px] max-w-[180px] h-[320px]
            sm:min-w-[220px] sm:max-w-[220px] sm:h-[380px]
            md:min-w-[240px] md:max-w-[240px] md:h-[420px]
            rounded-2xl overflow-hidden
            bg-black relative flex-shrink-0
          "
        >
          {% if block.settings.video != blank %}
            <video
              class="w-full h-full object-cover"
              autoplay
              muted
              loop
              playsinline
            >
              <source src="{{ block.settings.video }}" type="video/mp4">
            </video>

            <!-- Play Icon -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="bg-black/50 w-12 h-12 rounded-full flex items-center justify-center text-white">▶</div>
            </div>

          {% elsif block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              class="w-full h-full object-cover"
              loading="lazy"
              alt=""
              width="240"
              height="420"
            >
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<script src="{{ 'review-slider.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Customer Review Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Customer Reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review image"
        },
        {
          "type": "url",
          "id": "video",
          "label": "Video URL (MP4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Review Slider",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
