<h2 class="text-xl md:text-2xl lg:text-3xl font-bold mb-3 text-center text-gray-900 pt-8">Love at First Bite.</h2>
<p class="text-center text-sm md:text-base text-gray-600">Real dogs. Real reactions. Zero convincing required.</p>

<section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-10" data-reaction-section>
  <div class="relative">

    <!-- Left Arrow -->
    <button
      type="button"
      data-slide-prev
      class="absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-white/90 hover:bg-white w-10 h-10 rounded-full shadow hidden sm:flex items-center justify-center"
    >
      ‹
    </button>

    <!-- Right Arrow -->
    <button
      type="button"
      data-slide-next
      class="absolute right-0 top-1/2 -translate-y-1/2 z-10 bg-white/90 hover:bg-white w-10 h-10 rounded-full shadow hidden sm:flex items-center justify-center"
    >
      ›
    </button>

    <!-- Slider -->
    <div
      id="reviewSlider"
      data-review-slider
      class="flex gap-4 overflow-x-auto scroll-smooth no-scrollbar px-8 md:px-12"
    >
      {% for block in section.blocks %}
        <div
          class="review-card flex-shrink-0 w-[300px] h-[500px] rounded-2xl overflow-hidden bg-black relative"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.video != blank %}
            <video
              class="review-video"
              autoplay
              muted
              loop
              playsinline
            >
              <source src="{{ block.settings.video }}" type="video/mp4">
            </video>
          {% elsif block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              class="w-full h-full object-cover"
              loading="lazy"
              alt=""
              width="300"
              height="500"
            >
          {% endif %}

          <!-- Play icon: hidden by default, shown on hover via CSS -->
          {% if block.settings.video != blank %}
            <div class="play-icon absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200">
              <div class="bg-black/50 w-12 h-12 rounded-full flex items-center justify-center text-white">▶</div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .review-card { width: 300px !important; height: 500px !important; }
  .review-card .review-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .review-card:hover .play-icon { opacity: 1; }
</style>

<script src="{{ 'review-slider.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Customer Review Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Customer Reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review image"
        },
        {
          "type": "url",
          "id": "video",
          "label": "Video URL (MP4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Review Slider",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
