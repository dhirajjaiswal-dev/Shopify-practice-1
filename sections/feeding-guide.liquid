<section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-10">
  <div class="feeding-guide__container">
    <!-- LEFT IMAGE -->
    {% if section.settings.image != blank %}
      <div class="feeding-guide__image">
        {{ section.settings.image | image_url: width: 900 | image_tag: class: 'feeding-guide__img', loading: 'lazy' }}
      </div>
    {% endif %}

    <!-- RIGHT CONTENT -->
    <div class="feeding-guide__content text-center">
      {% if section.settings.heading != blank %}
        <h2 class="feeding-guide__title">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      <table class="feeding-guide__table">
        <thead>
          <tr>
            <th>Dog Weight</th>
            <th>Daily</th>
            <th>Monthly QTY</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td>{{ block.settings.weight }}</td>
              <td>{{ block.settings.daily }}</td>
              <td>{{ block.settings.monthly }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .feeding-guide {
    padding: 40px 0;
  }

  .feeding-guide__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    background: #fff;
    border-radius: 12px;
    padding: 32px;
  }

  .feeding-guide__image {
    border-radius: 12px;
    overflow: hidden;
  }

  .feeding-guide__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feeding-guide__title {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 24px;
  }

  .feeding-guide__table {
    width: 100%;
    border-collapse: collapse;
  }

  .feeding-guide__table th {
    text-align: center;
    font-weight: 600;
    padding: 14px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .feeding-guide__table td {
    text-align: center;
    padding: 16px 0;
    border-bottom: 1px solid #f0f0f0;
    color: #333;
  }

  /* Mobile / Tablet */
  @media (max-width: 1024px) {
    .feeding-guide__container {
      grid-template-columns: 1fr;
      padding: 20px;
    }

    .feeding-guide__title {
      font-size: 20px;
    }

    .feeding-guide__img {
      height: 240px;
    }

    .feeding-guide__table th,
    .feeding-guide__table td {
      padding: 8px 4px;
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Feeding Guide",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feeding guide"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Guide Row",
      "settings": [
        {
          "type": "text",
          "id": "weight",
          "label": "Dog Weight",
          "default": "Under 25 kg"
        },
        {
          "type": "text",
          "id": "daily",
          "label": "Daily Amount",
          "default": "1/2 Stick"
        },
        {
          "type": "text",
          "id": "monthly",
          "label": "Monthly Quantity",
          "default": "1 pack"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feeding Guide",
      "blocks": [{ "type": "row" }, { "type": "row" }, { "type": "row" }, { "type": "row" }]
    }
  ]
}
{% endschema %}
