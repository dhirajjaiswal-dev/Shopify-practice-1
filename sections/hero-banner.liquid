{% comment %}
  <section class="w-full overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 items-center min-h-[60vh] md:min-h-[80vh] gap-8">
        <!-- LEFT: Product Image -->
        <div class="w-full h-full flex items-center justify-center">
          {% if section.settings.image != blank %}
            <img
              src="{{ section.settings.image | image_url: width: 900 }}"
              alt="{{ section.settings.image.alt | escape }}"
              class="w-full h-auto object-contain"
              width="900"
              height="900"
              loading="eager"
            >
          {% endif %}
        </div>

        <!-- RIGHT: Text Content -->
        <div class="text-left">
          {% if section.settings.heading != blank %}
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
              {{ section.settings.heading }}
            </h1>
          {% endif %}

          {% if section.settings.subheading != blank %}
            <div class="text-lg md:text-xl mb-6 text-gray-600">
              {{ section.settings.subheading }}
            </div>
          {% endif %}

          {% if section.settings.button_label != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="inline-block bg-black text-white px-6 py-3 rounded-md hover:bg-gray-800 transition"
            >
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  {% schema %}
  {
    "name": "Hero Banner (Split)",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Product Image"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Your Product Heading"
      },
      {
        "type": "richtext",
        "id": "subheading",
        "label": "Subheading",
        "default": "<p>Short product description goes here</p>"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],
    "presets": [
      {
        "name": "Hero Banner Split"
      }
    ]
  }
  {% endschema %}
{% endcomment %}
