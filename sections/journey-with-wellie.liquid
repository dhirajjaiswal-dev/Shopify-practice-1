<section class="bg-[#FAF6F1] py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <!-- LEFT: Timeline -->
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-10">
          {{ section.settings.heading }}
        </h2>

        <div class="relative">
          {% for block in section.blocks %}
            <div class="relative flex gap-4{% unless forloop.last %} pb-10{% endunless %}" {{ block.shopify_attributes }}>

              <!-- Timeline spine: badge + dashed line -->
              <div class="flex flex-col items-center flex-shrink-0">
                <!-- Month badge -->
                <span class="inline-flex items-center whitespace-nowrap rounded-full border border-teal-500 text-teal-600 text-xs font-medium px-3 py-1 bg-white z-10">
                  {{ block.settings.month }}
                </span>
                <!-- Dashed connector (hidden on last step) -->
                {% unless forloop.last %}
                  <div class="flex-1 mt-1" style="width:1px; border-left: 2px dashed #9ca3af; min-height: 40px;"></div>
                {% endunless %}
              </div>

              <!-- Content -->
              <div class="pt-0.5 pb-2">
                <h3 class="text-base md:text-lg font-bold text-gray-900 mb-2 leading-snug">
                  {{ block.settings.title }}
                </h3>
                <ul class="space-y-1">
                  {% assign lines = block.settings.points | newline_to_br | split: '<br />' %}
                  {% for line in lines %}
                    {% if line != blank %}
                      <li class="flex items-start gap-2 text-sm text-gray-600">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0"></span>
                        <span>{{ line | strip }}</span>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>

            </div>
          {% endfor %}
        </div>
      </div>

      <!-- RIGHT: Image -->
      <div class="w-full">
        {% if section.settings.side_image != blank %}
          <img
            src="{{ section.settings.side_image | image_url: width: 800 }}"
            alt="Journey image"
            class="w-full rounded-2xl object-cover"
            loading="lazy"
            width="800"
            height="800"
          >
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journey With Wellie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Journey With Wellie"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Right side image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Journey Step",
      "settings": [
        {
          "type": "text",
          "id": "month",
          "label": "Month label",
          "default": "Month 1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Initial adaptation and digestive support"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Bullet points (one per line)",
          "default": "The prebiotics help improve nutrient absorption.\nEnhanced digestion often leads to an improved appetite."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Journey With Wellie",
      "blocks": [{ "type": "step" }, { "type": "step" }, { "type": "step" }]
    }
  ]
}
{% endschema %}
