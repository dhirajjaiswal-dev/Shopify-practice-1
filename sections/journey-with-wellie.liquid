<section class="max-w-7xl mx-auto px-20 py-7">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <!-- LEFT CONTENT -->
    <div>
      <h2 class="text-3xl text-center font-semibold text-gray-800 mb-10">
        {{ section.settings.heading }}
      </h2>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute text-center left-8 top-0 h-full w-px bg-dashed border-l border-gray-300"></div>

        <div class="space-y-12">
          {% for block in section.blocks %}
            <div class="relative pl-14">
              <!-- Month badge -->
              <span class="absolute left-0 top-0 inline-flex items-center justify-center rounded-full border border-teal-500 text-teal-600 text-xs font-medium px-3 py-1 bg-white">
                {{ block.settings.month }}
              </span>

              <h3 class="text-lg text-center font-semibold text-gray-800 mb-3">
                {{ block.settings.title }}
              </h3>

              <ul class="list-disc text-left pl-16 space-y-2 text-gray-600 text-sm">
                {% assign lines = block.settings.points | newline_to_br | split: '<br />' %}
                {% for line in lines %}
                  <li>{{ line }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- RIGHT IMAGE -->
    <div class="w-full">
      {% if section.settings.side_image != blank %}
        <img
          src="{{ section.settings.side_image | image_url: width: 800 }}"
          alt="Journey image"
          class="w-full rounded-xl object-cover"
          loading="lazy"
          width="800"
          height="800"
        >
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journey With Wellie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Journey With Wellie"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Right side image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Journey Step",
      "settings": [
        {
          "type": "text",
          "id": "month",
          "label": "Month label",
          "default": "Month 1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Initial adaptation and digestive support"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Bullet points (one per line)",
          "default": "The prebiotics help improve nutrient absorption.\nEnhanced digestion often leads to an improved appetite."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Journey With Wellie",
      "blocks": [{ "type": "step" }, { "type": "step" }, { "type": "step" }]
    }
  ]
}
{% endschema %}
