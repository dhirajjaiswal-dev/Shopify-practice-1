<section class="max-w-5xl mx-auto px-6 py-14">
  <h2 class="text-center text-2xl font-semibold text-gray-800 mb-10">FAQ’s</h2>

  <div class="space-y-4" id="faq-accordion-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="border-b border-gray-200 pb-4">
        <!-- Question -->
        <button
          type="button"
          class="w-full flex justify-between items-center text-left font-medium text-gray-800 text-lg faq-toggle"
        >
          <span>{{ block.settings.question }}</span>
          <span class="text-2xl transition-transform duration-300">+</span>
        </button>

        <!-- Answer -->
        <div class="faq-answer hidden mt-3 text-gray-600 leading-relaxed">
          {{ block.settings.answer }}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const accordion = document.getElementById('faq-accordion-{{ section.id }}');
    const toggles = accordion.querySelectorAll('.faq-toggle');

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const answer = toggle.nextElementSibling;
        const icon = toggle.querySelector('span:last-child');

        toggles.forEach((otherToggle) => {
          if (otherToggle !== toggle) {
            otherToggle.nextElementSibling.classList.add('hidden');
            otherToggle.querySelector('span:last-child').textContent = '+';
          }
        });

        answer.classList.toggle('hidden');
        icon.textContent = answer.classList.contains('hidden') ? '+' : '−';
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Can these treats replace my dog's regular diet?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "No, these treats are designed to supplement a balanced diet, not replace it."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [{ "type": "faq" }, { "type": "faq" }, { "type": "faq" }]
    }
  ]
}
{% endschema %}
