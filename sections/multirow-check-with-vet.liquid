{% assign entries = product.metafields.custom.multirow_check_with_vet.value %}

{% if entries != blank %}
  <section class="max-w-7xl mx-auto px-6 lg:px-20 py-10 space-y-8">
    {% for entry in entries %}
      <div class="bg-[#FAF7F5] rounded-2xl overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-10">
          <!-- Image -->
          {% if entry.image.value != blank %}
            <div>
              <img
                src="{{ entry.image.value | image_url: width: 900 }}"
                alt="{{ entry.sub_heading.value }}"
                class="w-full h-full object-cover rounded-2xl"
                loading="lazy"
                width="900"
                height="900"
              >
            </div>
          {% endif %}

          <!-- Content -->
          <div class="px-4 sm:px-8 lg:px-12 py-10">
            {% if entry.sub_heading.value != blank %}
              <h2 class="text-2xl lg:text-3xl font-semibold text-gray-800 mb-4">
                {{ entry.sub_heading.value }}
              </h2>
            {% endif %}
 
            {% if entry.description.value != blank %}
              <p
                id="vet-desc-{{ forloop.index }}"
                class="text-gray-600 leading-relaxed mb-6"
              >
                {{ entry.description.value }}
              </p>
            {% endif %}
    
            <!-- Copy Button -->
            <button
              type="button"
              onclick="copyVetTextMulti('vet-desc-{{ forloop.index }}', 'copy-btn-{{ forloop.index }}')"
              class="inline-flex items-center gap-2 bg-[#D6E4E5] text-teal-800 px-6 py-3 rounded-full font-medium hover:bg-teal-200 transition"
            >
              <img
                src="https://cdn.shopify.com/s/files/1/0733/3986/3212/files/File.png?v=1768355583"
                width="20"
                height="20"
                alt="copy icon"
              >
              <span id="copy-btn-{{ forloop.index }}">Copy Message</span>
            </button>
          </div>

        </div>
      </div>
    {% endfor %}
  </section>
{% endif %}

<script>
  function copyVetTextMulti(descId, btnId) {
    const text = document.getElementById(descId).innerText;
    const btn = document.getElementById(btnId);
    navigator.clipboard.writeText(text).then(() => {
      const original = btn.innerText;
      btn.innerText = 'Copied!';
      setTimeout(() => { btn.innerText = original; }, 2000);
    });
  }
</script>

{% schema %}
{
  "name": "Multirow Check with Vet",
  "settings": [],
  "presets": [
    {
      "name": "Multirow Check with Vet"
    }
  ]
}
{% endschema %}
