{%- assign ingredients = shop.metaobjects.feeding_guide.values -%}

<section class="bg-[#FFF9F7] py-14">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-20 py-10">

    {% if section.settings.heading != blank %}
      <h2 class="text-2xl md:text-3xl font-semibold text-center mb-10">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for ingredient in ingredients %}
        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition">

          {%- if ingredient.image.value != blank -%}
            <div class="aspect-[4/3] overflow-hidden">
              {{
                ingredient.image.value
                | image_url: width: 600
                | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: ingredient.heading.value
              }}
            </div>
          {%- endif -%}

          <div class="p-5 flex flex-col h-full">

            {%- if ingredient.heading.value != blank -%}
              <h3 class="text-base font-semibold text-gray-900 mb-2">
                {{ ingredient.heading.value }}
              </h3>
            {%- endif -%}

            {%- if ingredient.description.value != blank -%}
              <p class="text-sm text-gray-600 leading-snug mb-3">
                {{ ingredient.description.value | truncatewords: 15 }}<strong class="text-gray-900 cursor-pointer">...Read more</strong>
              </p>
            {%- endif -%}

            {%- if ingredient.tab.value != blank -%}
              <div class="flex flex-wrap gap-2">
                {%- assign tags = ingredient.tab.value | split: ',' -%}
                {%- for tag in tags -%}
                  <span class="text-xs font-medium px-3 py-1 rounded-full bg-teal-50 text-teal-700">
                    {{ tag | strip | upcase }}
                  </span>
                {%- endfor -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      {% else %}
        <p class="col-span-4 text-center text-gray-400 text-sm">No ingredients found. Add entries to the Premium Ingredients metaobject.</p>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Premium Ingredients",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Premium Ingredients"
    }
  ],
  "presets": [
    {
      "name": "Premium Ingredients"
    }
  ]
}
{% endschema %}
