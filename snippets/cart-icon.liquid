<button
  type="button"
  class="relative bg-transparent border-none cursor-pointer p-2"
  aria-label="Open cart"
  data-cart-open-trigger
>
  {% render 'icon-cart', class_name: 'w-6 h-6' %}

  <span
    class="cart-item-count absolute -top-1 -right-1 w-5 h-5 bg-[#025A60] text-white text-xs font-bold rounded-full flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
  >
    {{ cart.item_count }}
  </span>
</button>
