<cart-drawer
  class="fixed top-0 right-0 w-full max-w-md h-full bg-white z-40 transform translate-x-full transition-transform duration-300 shadow-2xl"
  data-cart-drawer
>
  <div class="flex flex-col h-full">

    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b">
      <h2 class="text-xl font-bold text-gray-900">Your Cart</h2>
      <button
        class="p-2 rounded-full hover:bg-gray-100 transition-colors"
        aria-label="Close cart"
        data-cart-drawer-close
      >
        {% render 'icon-close', class_name: 'w-5 h-5', color: 'black' %}
      </button>
    </div>

    <!-- Items -->
    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4" data-cart-items>
      {% for item in cart.items %}
        {% render 'cart-item', item: item, index: forloop.index %}
      {% endfor %}
    </div>

    <!-- Empty state -->
    <div
      class="flex-1 flex flex-col items-center justify-center px-5 py-12 {% if cart.item_count > 0 %}hidden{% endif %}"
      data-cart-empty
    >
      <svg class="w-16 h-16 text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h13M10 19a1 1 0 100 2 1 1 0 000-2zm7 0a1 1 0 100 2 1 1 0 000-2z"/>
      </svg>
      <p class="text-gray-500 font-medium">Your cart is empty</p>
      <button
        onclick="CartManager.close()"
        class="mt-4 text-sm text-[#025A60] font-semibold hover:underline"
      >
        Continue Shopping
      </button>
    </div>

    <!-- Footer -->
    <div
      class="border-t px-5 py-5 space-y-4 {% if cart.item_count == 0 %}hidden{% endif %}"
      data-cart-footer
    >
      <div class="flex items-center justify-between">
        <span class="text-gray-600 font-medium">Subtotal</span>
        <span class="text-lg font-bold text-gray-900" data-cart-total>
          {{ cart.total_price | money }}
        </span>
      </div>
      <p class="text-xs text-gray-400">Taxes and shipping calculated at checkout</p>
      <a
        href="/checkout"
        class="block w-full bg-teal-800 text-white text-center py-4 rounded-xl font-semibold hover:bg-teal-900 transition-colors"
      >
        Buy Now
      </a>
    </div>

  </div>
</cart-drawer>

<div class="cart-overlay fixed inset-0 bg-black bg-opacity-50 z-30 hidden" data-cart-overlay></div>
